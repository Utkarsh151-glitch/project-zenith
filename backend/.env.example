# Application
# Basic service identity and local debug mode.
APP_NAME="Project Zenith: The Celestial Eye"
APP_VERSION="0.1.0"
DEBUG=false

# External APIs
# Base URLs for third-party data providers used by the backend.
NASA_HORIZONS_URL="https://ssd.jpl.nasa.gov/api/horizons.api"
CELESTRAK_URL="https://celestrak.org"
OPEN_NOTIFY_URL="http://api.open-notify.org"
OPEN_METEO_URL="https://api.open-meteo.com"

# AI
# Replace with your OpenAI project API key for AI-powered features.
OPENAI_API_KEY="your-openai-api-key"

# Redis
# Redis connection URL for local development or deployment.
REDIS_URL="redis://localhost:6379/0"
